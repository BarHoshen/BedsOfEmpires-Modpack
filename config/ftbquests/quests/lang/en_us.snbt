	quest.3365B31B181F72C4.title: "Rank: Nuclear Alchemist"
	quest.33A47D79824E0B3A.quest_desc: [
		"Steam engines provide the most SU."
		"Feed a blaze burner with fuel for massive output."
	]
	quest.33BDE202DE6A1C9E.quest_desc: ["The Structure Compass points toward any structure in the world — dungeons, villages, enemy-built structures. A scout's most basic tool."]
	quest.33BDE202DE6A1C9E.quest_subtitle: "Find what's hidden"
	quest.33BDE202DE6A1C9E.title: "Trailblazer"
	quest.33FAE4FB82F735EE.quest_desc: ["Apotheosis gems socket into your gear, adding powerful stat bonuses. Combined with boss-drop weapons, you become the best-equipped fighter on the server."]
	quest.33FAE4FB82F735EE.quest_subtitle: "Socket your gear"
	quest.33FAE4FB82F735EE.title: "Gem Mastery"
