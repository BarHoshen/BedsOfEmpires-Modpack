	quest.AE00000000000001.quest_desc: [
		"Welcome to the Economy path. You'll grow resources from nothing, store thousands of items digitally, and build a self-sustaining empire."
		""
		"Here's a starter kit: inferium essence, prosperity shards, storage drawers, and a backpack. Three branches await: Storage Drawers, Mystical Agriculture, and Backpack Logistics."
	]
	quest.AE00000000000001.quest_subtitle: "Your economy begins here"
	quest.AE00000000000001.title: "Welcome to Economy"
