	quest.BA0000000000001C.quest_desc: ["Regeneration effect. The scout's best friend before dungeon raids."]
	quest.BA0000000000001C.quest_subtitle: "Warmth and healing"
	quest.BA0000000000001C.title: "Hot Chocolate"
	quest.BA0000000000001D.quest_desc: ["Regeneration II. The best healing item you can produce."]
	quest.BA0000000000001D.quest_subtitle: "Maximum regeneration"
