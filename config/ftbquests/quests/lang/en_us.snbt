	quest.36FC554BA8A349FF.title: "Thermonuclear Fusion"
	quest.3749E98E7C1E4058.quest_desc: [
		"Nuclear power via Create. Generates"
		"massive heat for stirling engines. Don't let it"
		"melt down — corium is NOT fun to clean up."
	]
	quest.37862EEB29AFBD84.quest_desc: ["Farmer's Delight adds a cooking system. Mystical Agriculture lets you grow resources. Here's a taste of both."]
