	quest.00025CFD0EB4E9AA.quest_desc: [
		"Steel casings are the frame of every"
		"Mekanism machine. Craft in bulk."
	]
	quest.00025CFD0EB4E9AA.title: "Steel Casing"
	quest.00948C3F101396D7.quest_desc: [
		"Time to use that radar. Get within range of an enemy base and study their defenses. How many layers of walls? Where are the cameras? Where's the bed?"
		""
		"Don't engage — observe. A good scout brings intel back alive."
	]
	quest.00948C3F101396D7.quest_subtitle: "Study the enemy"
	quest.00948C3F101396D7.title: "Recon Kit"
	quest.00B13FC0B1D6A652.quest_desc: ["AE2 can craft items on demand. Set up a pattern and your system crafts automatically when you request it."]
	quest.00B13FC0B1D6A652.quest_subtitle: "Craft on demand"
	quest.00B13FC0B1D6A652.title: "Auto-Crafting"
	quest.00C6E87F2713BD80.quest_desc: [
		"Programmable item routing. Direct"
		"items to specific machines/chests by type."
	]
	quest.00C6E87F2713BD80.title: "Logistical Sorter"
	quest.01AF4087E827D7B3.quest_desc: ["Warp Scrolls teleport you to a saved location. One-time use but incredibly useful."]
	quest.01AF4087E827D7B3.title: "Warp Scroll"
	quest.01BD63E297D2B45A.quest_desc: ["Have 10 different Create machines running simultaneously."]
	quest.01BD63E297D2B45A.quest_subtitle: "10 machines running"
	quest.02D38BC746F230CB.quest_desc: [
		"Handheld tools from Create S&A."
		"The drill mines, the flamethrower smelts,"
		"the whisk grapples."
	]
	quest.032D8D0A019D7A2E.quest_desc: ["A scout finds what others miss. The Structure Compass locates any structure in the world — dungeons, villages, even enemy-built structures. Here's a spyglass too."]
	quest.032D8D0A019D7A2E.quest_subtitle: "Find what's hidden"
	quest.032D8D0A019D7A2E.title: "Taste of Scouting"
	quest.035E571871B49883.quest_desc: [
		"Stores stress units. Charge when"
		"you have excess power, discharge when needed."
	]
	quest.0364349D6641517B.quest_desc: ["Stabilized Warp Scrolls are reusable. Bind them to key locations."]
	quest.0364349D6641517B.title: "Stabilized Warp Scroll"
	quest.03C0CDC3344A8D12.quest_desc: [
		"The Copy Paste Gadget records block layouts in a 3D template. Sneak close to an enemy base and scan their defenses — walls, traps, turrets, everything."
		""
		"Bring the template back to your team. Now they know EXACTLY what they're attacking: where the weak points are, where the bed might be, and where the mines are hidden."
		""
		"This is how wars are won — not with brute force, but with intelligence."
	]
	quest.03C0CDC3344A8D12.quest_subtitle: "Copy their base layout"
	quest.03C0CDC3344A8D12.title: "Blueprint Thief"
	quest.03D86DE9D055EE43.quest_desc: [
		"Place in flowing water for passive SU."
		"Multiple wheels on one shaft = more power."
	]
	quest.03F3DFF4D019DD8E.quest_desc: ["Sourcelinks generate source passively. Volcanic burns fuel, Agronomic feeds on crop growth, Mycelial on food consumption."]
	quest.03F3DFF4D019DD8E.title: "Your First Sourcelink"
	quest.04368EF3E521824A.quest_desc: [
		"You can fly. Reconnaissance, supply"
		"runs, or... bombing runs."
	]
	quest.0456D5B6ABCE8EFD.quest_desc: ["The Spell Bow fires arrows infused with your Projectile spell. Devastating at range."]
	quest.0456D5B6ABCE8EFD.title: "Enchanter's Bow"
	quest.048E104AF2811693.quest_desc: ["Elite circuits unlock the Digital Miner and advanced factories. Your transmutation capabilities grow exponentially."]
	quest.048E104AF2811693.quest_subtitle: "Master transmuter"
	quest.048E104AF2811693.title: "Elite Processing"
	quest.0498EA8FD481E0BD.quest_desc: ["Iron's Spells bosses guard structures and drop powerful loot. Bring potions and good armor."]
	quest.0498EA8FD481E0BD.title: "Iron's: First Boss"
	quest.05391668D50EE5E2.quest_desc: ["Effect glyph — applies bonemeal to crops and saplings. Projectile + Grow + AOE = instant farm."]
	quest.05391668D50EE5E2.title: "Glyph: Grow"
	quest.057DB04B5ACA5675.quest_desc: ["A real factory processes items through multiple stages automatically. Build one."]
	quest.057DB04B5ACA5675.quest_subtitle: "Multi-stage processing"
	quest.0595F0137D1E2FDD.quest_desc: ["Makes you invisible. Self + Invisibility = stealth mode. Great for recon."]
	quest.0595F0137D1E2FDD.title: "Glyph: Invisibility"
	quest.05F57AA45DAD1ABC.quest_desc: ["Familiar that grants Speed 2 buff while nearby."]
	quest.05F57AA45DAD1ABC.title: "Familiar: Starbuncle"
	quest.06184E2EB25731E8.quest_desc: [
		"Steam-powered flight using both water"
		"and fuel. The best mid-tier jetpack."
	]
	quest.063853173C988B14.quest_desc: [
		"Converts SU to FE. Your Create factory"
		"can now power Mekanism machines and laser turrets."
	]
	quest.0729A1464A53F8A6.title: "Teleportation Core"
	quest.078676B286E994A0.quest_desc: ["Kill an Apothic Invader using only magic damage."]
	quest.078676B286E994A0.quest_subtitle: "Transcendent"
	quest.078676B286E994A0.title: "Magical Supremacy"
	quest.079ED8FFE21571CA.quest_desc: ["Your base is now magically protected from mob spawns. Combined with spell turrets, casual attackers can't approach."]
	quest.079ED8FFE21571CA.quest_subtitle: "Magical protection"
	quest.079ED8FFE21571CA.title: "Wardstone"
	quest.07F31B0ACD72D0C6.quest_desc: ["Lock your doors. Only you know the code."]
	quest.07F31B0ACD72D0C6.quest_subtitle: "Secure access"
	quest.07F31B0ACD72D0C6.title: "Lockdown"
	quest.081135031BFD24F2.title: "Crusher"
	quest.08C398BC8CB044AE.quest_desc: ["You can generate source, cast basic spells, and understand glyph combinations. The Enchanting Apparatus unlocks advanced crafting."]
	quest.08C398BC8CB044AE.title: "Rank: Mage"
	quest.09443F6E80D69565.title: "MekaSuit Pants"
	quest.096C7A51B3680CEC.quest_desc: ["No more manual mining. Build a drill contraption that mines for you. This is the turning point — resources are no longer a bottleneck."]
	quest.096C7A51B3680CEC.quest_subtitle: "No more pickaxes"
	quest.09E25C40875FC0CF.quest_desc: [
		"You understand rotation, processing,"
		"and logistics. Time for advanced engineering."
	]
	quest.0A70434DC71800DD.quest_desc: ["Place the Ritual Brazier and surround it with Arcane Pedestals holding tablets."]
	quest.0A70434DC71800DD.title: "Ritual Brazier"
	quest.0AAE809744D95EAE.quest_desc: ["SecurityCraft protects your base with cameras, mines, and lasers. Reinforce a block to get started — here's a security starter kit."]
	quest.0AAE809744D95EAE.quest_subtitle: "Reinforce and detect"
	quest.0B33607D326F1D7A.quest_desc: ["Forces targets to fall. Negates slow falling and pulls flying mobs down."]
	quest.0B33607D326F1D7A.title: "Glyph: Gravity"
	quest.0B465F1D269A6D54.title: "Module: Teleportation"
	quest.0B6222FDCC03CE57.quest_desc: ["Place water wheels in a river to generate rotational force (SU). Here's extras — you'll want a big power setup."]
	quest.0B6222FDCC03CE57.quest_subtitle: "Harness the river"
	quest.0BB5452291A3DBF1.quest_desc: ["You have mastered every school of magic. Reality bends to your will."]
	quest.0BB5452291A3DBF1.title: "Arcane Supremacy"
	quest.0C002A2917B7101B.quest_desc: ["Grants creative flight to nearby players. The mage's answer to jetpacks."]
	quest.0C002A2917B7101B.title: "Ritual: Flight"
	quest.0C20DDD7B0CDD205.title: "SPS Casing"
	quest.0C8A6D6E2A22EAD6.quest_desc: ["Your journey into magic begins. Source gems power everything — plant sourceberry bushes for a renewable supply."]
	quest.0C8A6D6E2A22EAD6.quest_subtitle: "Begin the arcane path"
	quest.0C8A6D6E2A22EAD6.title: "Arcane Initiate"
	quest.0CE97B7924828180.quest_desc: [
		"The heart of Create automation. Items"
		"move through deployers, presses, and cutters"
		"in a precise sequence."
	]
	quest.0D1C6A2F7A7AAB8A.quest_desc: [
		"Mekanism's infused alloys are essential for advanced circuits — and they're a pain to produce without a proper setup. 64 of them is a real grind."
		""
		"Solo: you'd need to build a Metallurgic Infuser and process redstone+iron manually. With an Alchemy teammate: they're mass-producing alloys already. Trade brass for alloys."
	]
	quest.0D1C6A2F7A7AAB8A.quest_subtitle: "Cross-discipline materials"
	quest.0D1C6A2F7A7AAB8A.title: "Alchemical Alloys"
	quest.0D5F15ABE3B9A51B.quest_desc: ["Launches targets upward. Combine with Harm for fall damage kills."]
	quest.0D5F15ABE3B9A51B.title: "Glyph: Launch"
	quest.0D7AE5912F8D229A.quest_desc: [
		"Windmills work everywhere and scale with"
		"sail count. Your first serious power source."
	]
	quest.0E73D67EC534555F.quest_desc: ["A spell of incredible complexity. You are the most dangerous magic user on the server."]
	quest.0E73D67EC534555F.quest_subtitle: "Archmage"
	quest.0E73D67EC534555F.title: "Ultimate Caster"
	quest.0EDF50572BC06432.quest_desc: ["Launch splash potions at enemies. Combined with Ars Nouveau custom potions, this is devastating in PvP."]
	quest.0EDF50572BC06432.title: "Flask Cannon"
	quest.0F4F1815AD0F8C9D.quest_desc: ["Defeat 3 different Iron's Spells bosses to prove your combat magic prowess."]
	quest.0F4F1815AD0F8C9D.title: "Boss Hunter: 3 Bosses"
	quest.0F6E178A5F86A469.quest_desc: [
		"Catalysts let fans bulk-process items"
		"without needing lava/water/soul fire."
	]
	quest.0F734267174BEE81.quest_desc: ["Summons a lightning bolt on the target. Touch + Lightning + Split = chain lightning."]
	quest.0F734267174BEE81.title: "Glyph: Lightning"
	quest.102E955389416576.quest_desc: ["Augment glyph — splits a projectile into multiple copies. More targets, more chaos."]
	quest.102E955389416576.title: "Glyph: Split"
	quest.10781200C784571E.title: "Chemical Oxidizer"
	quest.11A0D380EC5446E3.quest_desc: ["Extends potion duration while this familiar is active."]
	quest.11A0D380EC5446E3.title: "Familiar: Wixie"
	quest.12BD051B12521D5F.quest_desc: [
		"Mount drills on a bearing or piston."
		"Automated mining without pickaxes."
	]
	quest.1315726709FEE962.quest_desc: ["A wall around your base is the most basic defense. Make it tall."]
	quest.1315726709FEE962.quest_subtitle: "Build your fortress"
	quest.1315726709FEE962.title: "First Walls"
	quest.13A5231CAABC64C6.title: "Universal Cable"
	quest.144EE6864F5F45D0.quest_desc: ["To truly earn the Archmage title, you must defeat the Wilden Chimera. The ritual tablet requires Horn + Wing + Spike from Wilden mobs."]
	quest.144EE6864F5F45D0.title: "Rank: Archmage"
	quest.146604BE3DFC35C0.quest_desc: ["Manual reloading is for amateurs. Automate your cannon's ammo supply."]
	quest.146604BE3DFC35C0.quest_subtitle: "Automated ammunition"
	quest.146604BE3DFC35C0.title: "Auto-Loader"
	quest.14CAED92F96C6DFE.title: "MekaSuit Helmet"
	quest.1532909F6DB1BA3B.quest_desc: ["The Bed Compass points toward the nearest enemy bed. You're now on the offensive."]
	quest.1532909F6DB1BA3B.quest_subtitle: "Seek and destroy"
	quest.1532909F6DB1BA3B.title: "Bed Hunter"
	quest.15A90F9620500EAA.quest_desc: [
		"Converts heat to rotation. Solar plates"
		"heat pipes, stirling engines spin shafts. Free power."
	]
	quest.16C27A54A4B90DBC.quest_desc: ["Permanent portal network. Link your base to outposts across dimensions."]
	quest.16C27A54A4B90DBC.title: "Warp Portal"
	quest.16C79F32CB3D06A6.quest_desc: [
		"Doubles ore output. The foundation"
		"of all alchemy — transmuting raw stone into value."
	]
	quest.16C79F32CB3D06A6.title: "Enrichment Chamber"
	quest.176B32BA4C791E8B.quest_desc: ["The Reforging Table rerolls affixes on your gear. Combined with Gems and boss-drop weapons, you can min-max your equipment to perfection."]
	quest.176B32BA4C791E8B.quest_subtitle: "Perfect your loadout"
	quest.176B32BA4C791E8B.title: "Reforging Master"
	quest.17E49768A2C2594D.quest_desc: [
		"Trains move items and players across"
		"vast distances. Connect your base to outposts."
	]
	quest.180FD5020EBCC2C4.quest_desc: ["Mystical Agriculture lets you GROW resources. No more mining — plant iron seeds, harvest iron."]
	quest.180FD5020EBCC2C4.quest_subtitle: "Grow anything"
	quest.180FD5020EBCC2C4.title: "Mystical Agriculture"
	quest.18559172EBBD4C0A.quest_desc: ["Effect glyph — mines blocks at range. Projectile + Break + AOE = mass excavation."]
	quest.18559172EBBD4C0A.title: "Glyph: Break"
	quest.18725BD54F87CAEA.quest_desc: ["Build an enchanting table. Here are the bookshelves and lapis to get started right away."]
	quest.18725BD54F87CAEA.quest_subtitle: "Power up your gear"
	quest.1880DE6DBE388531.quest_desc: ["Airships aren't safe anymore. Connect SecurityCraft sensors to trigger Create Big Cannons automatically."]
	quest.1880DE6DBE388531.quest_subtitle: "No fly zone"
	quest.1880DE6DBE388531.title: "Anti-Air Emplacement"
	quest.18F760BFA7B047DB.title: "Ultimate Factory"
	quest.1902B1EA80E395F8.quest_desc: ["Socket Apotheosis gems into your magic gear. A Scout teammate has surplus sigils."]
	quest.1902B1EA80E395F8.title: "Gem-Socketed Staves"
	quest.19FA226E0E26ACF1.quest_desc: [
		"Top-tier energiser + motor. Your"
		"factory runs at maximum efficiency."
	]
	quest.1AF59A51F1BC47BA.quest_desc: ["The Ancient Codex is the ultimate Iron's Spells relic. It holds lost knowledge of the most powerful combat spells."]
	quest.1AF59A51F1BC47BA.title: "Ancient Codex"
	quest.1B472F5F4A8DBF18.quest_desc: [
		"Safety first. Clutches prevent"
		"overstress damage. Brakes halt networks."
	]
	quest.1B5FFC280183DD76.quest_desc: [
		"Infuses materials with redstone,"
		"carbon, or other elements. Creates alloys."
	]
	quest.1B5FFC280183DD76.title: "Metallurgic Infuser"
	quest.1B778D84D9E733D6.quest_desc: ["Form glyph — fires a projectile that carries your spell effects. Projectile + Harm + Amplify = ranged damage nuke."]
	quest.1B778D84D9E733D6.title: "Glyph: Projectile"
	quest.1B9E765C26ECDC01.quest_desc: ["Cooked meals give nourishment — a food buff that matters in prolonged PvP fights."]
	quest.1B9E765C26ECDC01.quest_subtitle: "Gourmet meals"
	quest.1B9E765C26ECDC01.title: "The Cooking Pot"
	quest.1D9E3D67035B33F9.quest_desc: [
		"Diesel engines provide serious SU"
		"from liquid fuel. Industrial-grade power."
	]
	quest.1DC79F29C506FE0E.quest_desc: ["Effect glyph — increases damage taken by the target. Stack with Harm for devastating combos."]
	quest.1DC79F29C506FE0E.title: "Glyph: Hex"
	quest.1DD6334C227B5FC1.quest_desc: ["Mithril armor enhances spell power and provides strong physical protection. The mage's answer to Mekanism's Refined Obsidian."]
	quest.1DD6334C227B5FC1.quest_subtitle: "Legendary metal"
	quest.1DD6334C227B5FC1.title: "Mithril Forged"
	quest.1EACAE6C65BEEB23.quest_desc: ["Auto-pickup items and XP orbs while this familiar is active."]
	quest.1EACAE6C65BEEB23.title: "Familiar: Bookwyrm"
	quest.1EFBBEE9667ABF3E.quest_desc: [
		"Mixers combine items in basins."
		"Essential for brass alloy."
	]
	quest.1F69A262C6D42C6E.quest_desc: ["Have 5+ different automated defense systems active: cameras, mines, lasers, turrets, golems, cannons."]
	quest.1F69A262C6D42C6E.quest_subtitle: "Commander"
	quest.1F69A262C6D42C6E.title: "Fortress"
	quest.208C13246EBFCBEA.title: "World Tier: Frontier"
	quest.20D06EA867124CC0.quest_desc: ["Mithril is a rare magical metal dropped by Iron's Spells bosses and found in structures."]
	quest.20D06EA867124CC0.title: "Mithril Ingot"
	quest.21000C665EF085FA.quest_desc: ["Ultimate circuits unlock nuclear transmutation. You're entering the domain of the Nuclear Alchemist."]
	quest.21000C665EF085FA.quest_subtitle: "The final formula"
	quest.21000C665EF085FA.title: "Ultimate Circuits"
	quest.213B6B09EA035CC2.quest_desc: ["Instantly digs 4 holes to bedrock. Rapid resource extraction."]
	quest.213B6B09EA035CC2.title: "Ritual: Burrowing"
	quest.218F95225C995F84.quest_desc: [
		"A flying weapons platform. Requires"
		"both Engineering (airship) and Military (cannon)."
		"This is a cross-path bonus quest."
	]
	quest.21D2AE2BF288D9C2.quest_desc: [
		"Cataclysm bosses hit hard. Soothing Hot Chocolate gives Regeneration II, gingerbread gives Resistance, combat chocolates give Speed and Haste."
		""
		"Solo: you'd need to set up Create Confectionery processing from scratch. With a Housewife teammate: they're swimming in chocolates. Raid prep is a team effort."
	]
	quest.21D2AE2BF288D9C2.quest_subtitle: "Chocolate before dungeons"
	quest.21D2AE2BF288D9C2.title: "Dungeon Rations"
	quest.2227FE26D06D048D.quest_desc: ["Potion Flasks hold multiple doses and can be customized with Ars Nouveau effects."]
	quest.2227FE26D06D048D.title: "Potion Flask"
	quest.22490E5094943A73.quest_desc: ["+2 earth spell damage while this familiar is active."]
	quest.22490E5094943A73.title: "Familiar: Drygmy"
	quest.22515B694097C5DA.quest_desc: ["A scout moves at night. Prove you can survive the darkness — the mobs you face out here are nothing compared to what guards enemy bases."]
	quest.22515B694097C5DA.quest_subtitle: "Own the darkness"
	quest.22515B694097C5DA.title: "Night Runner"
	quest.22705E51AE8BC3B8.quest_desc: ["Summons evoker-style fangs. Hits through shields and armor."]
	quest.22705E51AE8BC3B8.title: "Glyph: Fangs"
	quest.22FDB27E6B0C558E.quest_desc: ["Spell turrets auto-cast spells at targets. This is your magical equivalent of SecurityCraft turrets. Set them to cast damage spells at intruders."]
	quest.22FDB27E6B0C558E.quest_subtitle: "Automated magical defense"
	quest.22FDB27E6B0C558E.title: "Spell Turret Defense"
	quest.2303181F76DA78E1.quest_desc: ["The ultimate Iron's Spells boss. 1000 hearts. Bring everything you have."]
	quest.2303181F76DA78E1.title: "Echo of Tyros"
	quest.232F21F09B6F6BB9.quest_desc: ["Effect glyph — summons a swarm of vexes to attack your enemies."]
	quest.232F21F09B6F6BB9.title: "Glyph: Summon Vex"
	quest.23302A0268BB62A7.quest_desc: [
		"Brass = copper + zinc in a mixer."
		"This unlocks the advanced tier of Create."
	]
	quest.2380C33021DA7C1C.quest_desc: ["Place the Enchanting Apparatus you received as a reward. It is the core crafting station for all advanced Ars Nouveau items."]
	quest.2380C33021DA7C1C.title: "Enchanting Apparatus"
	quest.23B90E16748749AE.quest_desc: ["Ars Elemental adds elemental specialization to your spells. Fire, water, earth, air — each has unique combat applications."]
	quest.23B90E16748749AE.quest_subtitle: "Fire, water, earth, air"
	quest.23B90E16748749AE.title: "Elemental Power"
	quest.23BAEC441799CEAE.quest_desc: ["Effect glyph — animates nearby blocks to fight for you. Your walls become your army."]
	quest.23BAEC441799CEAE.title: "Glyph: Animate Block"
	quest.23E645132A993AB3.quest_desc: ["Open your spell book, add glyphs, and cast. Projectile + Break is a good first combo."]
	quest.23E645132A993AB3.quest_subtitle: "Cast your first spell"
	quest.23E645132A993AB3.title: "First Spell"
	quest.23F86E3273BD9F5E.quest_desc: ["Your factory runs itself. You can focus on strategy now."]
	quest.23F86E3273BD9F5E.quest_subtitle: "Fully autonomous"
	quest.24A80B8520829D08.quest_desc: ["Find an Iron's Spells structure — Mountain Tower, Mangrove Hut, or similar. These contain scroll loot and spell knowledge."]
	quest.24A80B8520829D08.title: "First Structure"
	quest.24C2D98739F0466F.quest_desc: ["Cameras let you watch your perimeter remotely from inside your base."]
	quest.24C2D98739F0466F.quest_subtitle: "Eyes everywhere"
	quest.24C2D98739F0466F.title: "Surveillance State"
	quest.25E651B48BDA8CD7.quest_desc: ["Diesel generators provide serious power. Industrial revolution complete."]
	quest.25E651B48BDA8CD7.quest_subtitle: "Fossil fuel power"
	quest.2645BD3689C4364B.quest_desc: ["The Enchantment Library stores enchantments for later use. Combined with Tomes, you can extract, store, and apply the perfect enchantment loadout for any mission."]
	quest.2645BD3689C4364B.quest_subtitle: "Store and extract enchantments"
	quest.2645BD3689C4364B.title: "Enchantment Library"
	quest.268B98EA5DAF28AD.quest_desc: [
		"Five different Cataclysm boss weapons in your arsenal. Each one has a unique ability that no amount of enchanting or crafting can replicate."
		""
		"You didn't build your power — you took it from the strongest creatures in the world."
	]
	quest.268B98EA5DAF28AD.quest_subtitle: "Dungeon-forged legend"
	quest.268B98EA5DAF28AD.title: "Legendary Arsenal"
	quest.26A53255D98A3B2C.quest_desc: [
		"The ultimate jetpack. Faster, longer"
		"flight, higher fuel capacity."
	]
	quest.26E163EC57A092B6.quest_desc: ["Effect glyph — heals allies. Touch + Heal + Amplify = powerful healing spell."]
	quest.26E163EC57A092B6.title: "Glyph: Heal"
	quest.27ADE9DFD380AA13.title: "Solar Generator"
	quest.27DEEA29F46A946C.quest_desc: ["A more powerful spellbook for Iron's Spells. More spell slots and higher tier spells."]
	quest.27DEEA29F46A946C.title: "Iron's: Enchanted Book"
	quest.286659886718BA90.quest_desc: ["The ultimate world difficulty. Only the strongest survive."]
	quest.286659886718BA90.quest_subtitle: "The apex"
	quest.286659886718BA90.title: "World Tier: Pinnacle"
	quest.28D4EA4C6CC1892D.title: "Atomic Alloy"
	quest.28F3E68727771EC6.quest_desc: ["Your digital storage system is massive. Wireless terminals let you access it from anywhere in your base."]
	quest.28F3E68727771EC6.quest_subtitle: "500+ item types"
	quest.28F3E68727771EC6.title: "Digital Empire"
	quest.28F45DFC12538123.quest_desc: ["Destroy a block using a cannon mounted on an airship."]
	quest.28F45DFC12538123.quest_subtitle: "Ace"
	quest.28F45DFC12538123.title: "Aerial Bombardment"
	quest.28F77AE23BE4F507.quest_desc: [
		"Your survival skills are proven. Seven paths lie before you:"
		""
		"⚙️ Engineering — Build factories, trains, and airships with Create"
		"⚗️ Magic — Master spells and rituals with Ars Nouveau"
		"🛡️ Military — Fortify, arm, and conquer with SecurityCraft and Big Cannons"
		"🌾 Economy — Farm, store, and automate with Mystical Agriculture and AE2"
		"🔬 Alchemy — Transmute, process, and go nuclear with Mekanism"
		"🏠 Housewife — Cook, decorate, and nurture with Farmer's Delight and Create"
		"👁️ Scout — Explore, infiltrate, and sabotage with Cataclysm and Apotheosis"
		""
		"You can pursue multiple paths. The resources here will get you started on any of them."
	]
	quest.28F77AE23BE4F507.quest_subtitle: "Seven paths await"
	quest.2928CDDB503AA804.quest_desc: ["Apothic Enchanting adds special bookshelves that unlock powerful enchantments beyond vanilla. Hellshelves and seashelves are the foundation."]
	quest.2928CDDB503AA804.quest_subtitle: "Beyond vanilla enchanting"
	quest.2928CDDB503AA804.title: "Enchanting Foundations"
	quest.293F5F44DF3F277A.quest_desc: ["Win a game of Beds of Empires — be the last player/team with a surviving bed."]
	quest.293F5F44DF3F277A.quest_subtitle: "Emperor"
	quest.293F5F44DF3F277A.title: "Last Bed Standing"
	quest.29CB582528B35232.quest_desc: ["Fires on a timer. Combined with Spell Prisms that redirect projectiles, you can build elaborate defense networks."]
	quest.29CB582528B35232.title: "Timer Turret"
	quest.2A0E62E2EE0B6A90.quest_desc: ["Your first airship. You can now reach places no one else can. Reconnaissance, supply runs, or... bombing runs."]
	quest.2A0E62E2EE0B6A90.quest_subtitle: "Take to the skies"
	quest.2A7051C2B85A1C78.quest_desc: ["X-ray vision for any block type. Find ores, find enemy chests, find beds."]
	quest.2A7051C2B85A1C78.title: "Ritual: Scrying"
	quest.2B0B0C11437B3B23.quest_desc: ["Mekanism machines need power. Heat generators burn fuel, solar harnesses the sun — every alchemist needs an energy source."]
	quest.2B0B0C11437B3B23.quest_subtitle: "Fuel the transmutations"
	quest.2B0B0C11437B3B23.title: "Power Generation"
	quest.2B31C2F4F1947DFB.quest_desc: [
		"Crushing doubles ore output and"
		"breaks items into components."
	]
	quest.2B5D1F8E8079D6B8.quest_desc: [
		"Soldiers fight harder on a full stomach. Stock your armory with 32 high-tier meals — Steak and Potatoes gives Nourishment that prevents hunger drain mid-combat."
		""
		"Solo: you'd need to set up farming, cooking, and gather dozens of ingredients. With a Housewife teammate: they have surplus meals from their quest rewards. Ask nicely."
	]
	quest.2B5D1F8E8079D6B8.quest_subtitle: "Fed soldiers fight harder"
	quest.2B5D1F8E8079D6B8.title: "Battle Rations"
	quest.2BB37F6C2C4C88D2.quest_desc: ["Passive mob loot production. Give a wild Drygmy a Wilden Horn for the token."]
	quest.2BB37F6C2C4C88D2.title: "Drygmy"
	quest.2BD4FB36B4F02707.quest_desc: [
		"Gearboxes redirect rotation."
		"Essential for complex factory layouts."
	]
	quest.2BF1377E8F61FCFE.quest_desc: [
		"Automated trains run without you."
		"Set destinations and conditions."
	]
	quest.2C5032FC05C16B6B.quest_desc: ["Higher essence tiers unlock better seeds. Growth accelerators speed everything up."]
	quest.2C5032FC05C16B6B.quest_subtitle: "Higher tier seeds"
	quest.2C5032FC05C16B6B.title: "Resource Crops"
	quest.2C606037D84261B2.quest_desc: ["Augment glyph — projectiles pass through targets hitting multiple enemies in a line."]
	quest.2C606037D84261B2.title: "Glyph: Pierce"
	quest.2C69B887860C391B.quest_desc: ["More spell slots. You're building a combat spellcaster alongside your Ars mage."]
	quest.2C69B887860C391B.title: "Iron's Spellbook: Iron"
	quest.2D1BD3FC915711FB.quest_desc: ["Source jars store liquid source. Accumulators and sourcelinks generate it passively. Set up a source production system."]
	quest.2D1BD3FC915711FB.quest_subtitle: "Generate source passively"
	quest.2D1BD3FC915711FB.title: "Source Well"
	quest.2D5ECC4509C36C47.quest_desc: [
		"Wireless transfer of items, fluids,"
		"gas, and energy across any distance."
	]
	quest.2D5ECC4509C36C47.title: "Quantum Entangloporter"
	quest.2D9128251B219C48.quest_desc: ["Apply threads to armor for perks: speed, mana boost, life drain, gliding..."]
	quest.2D9128251B219C48.title: "Alteration Table"
	quest.2DC05C32887473A3.quest_desc: ["The ultimate Create weapon — an airship that rains destruction. Requires both Engineering (airship) and Military (cannon) expertise."]
	quest.2DC05C32887473A3.quest_subtitle: "Death from above"
	quest.2E34C5DBD0CD8172.title: "MekaSuit Boots"
