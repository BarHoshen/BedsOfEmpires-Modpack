	quest.2E537EADD2221E3D.quest_subtitle: "Deeper transmutations"
	quest.2E537EADD2221E3D.title: "Advanced Processing"
	quest.300204A9D9CD4A1C.quest_desc: [
		"The endgame power system. Converts"
