		"the earth yields to the alchemist."
	]
	quest.4DA044C0BD2B4180.title: "Digital Miner"
	quest.4E9CE7F2B4753322.quest_desc: ["You have mastered advanced magic, defeated bosses, and built arcane infrastructure. The final mysteries of the arcane await."]
	quest.4E9CE7F2B4753322.title: "Rank: Transcendent"
	quest.4EAB4F00D8D053EC.quest_desc: [
		"The ultimate sabotage mission. You've scouted their base, you know the layout. Now destroy their most critical system — their AE2 controller, Mekanism reactor, or Create factory core."
		""
		"Without their automation backbone, they're reduced to manual labor while your team moves in for the kill."
	]
	quest.4EAB4F00D8D053EC.quest_subtitle: "Cripple an empire"
	quest.4EAB4F00D8D053EC.title: "Operation: Lights Out"
