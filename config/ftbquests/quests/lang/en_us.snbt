	quest.48307E92D95E8291.quest_desc: [
		"Transmute. Transform. Transcend."
		""
		"Mekanism powers the alchemist's path —"
		"ore processing, circuits, gas systems,"
		"and eventually nuclear energy."
		"Here are supplies to get started."
	]
	quest.48307E92D95E8291.quest_subtitle: "Transmute. Transform. Transcend."
	quest.48307E92D95E8291.title: "Welcome to Alchemy"
	quest.48E4E0DCF4D1B289.quest_desc: ["Factories process multiple items simultaneously. Industrial-scale transmutation."]
	quest.48E4E0DCF4D1B289.quest_subtitle: "Scale your operations"
	quest.48E4E0DCF4D1B289.title: "Factory Upgrade"
	quest.493BAFBB81EE7A58.quest_desc: [
		"Presses turn ingots to sheets."
		"Place above a depot or belt."
	]
	quest.49685B9D9614E170.quest_desc: ["Gas processing is Mekanism's unique mechanic. Oxidize, compress, and inject gases for advanced materials — true elemental transformation."]
	quest.49685B9D9614E170.quest_subtitle: "Gaseous transmutation"
	quest.49685B9D9614E170.title: "Gas Processing"
	quest.4B4C1CFCCBB00D74.quest_desc: ["Welcome to Beds of Empires. Your bed is your life — if it's destroyed and you die, you're out. Start by gathering wood and prepare to defend your bed through the night."]
	quest.4B4C1CFCCBB00D74.quest_subtitle: "Every journey starts here"
	quest.4B7893AC3CB2935B.quest_desc: ["The Inscription Table lets you assign spells to your spellbook slots."]
	quest.4B7893AC3CB2935B.title: "Inscription Table"
	quest.4CA2664EF8852E9D.quest_desc: ["Arcanist robes offer balanced defense and thread slots. The choice for a pure spellcaster who needs some protection."]
