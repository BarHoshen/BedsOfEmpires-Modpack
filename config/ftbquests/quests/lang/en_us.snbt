	quest.BA0000000000001E.quest_desc: ["Guardian tails are a rare ocean ingredient. Cook them for unique seafood meals."]
	quest.BA0000000000001E.quest_subtitle: "Hunt the guardians"
	quest.BA0000000000001E.title: "Guardian Tail"
	quest.BA0000000000001F.quest_desc: ["Tentacles from ocean mobs make exotic skewered meals."]
	quest.BA0000000000001F.quest_subtitle: "Exotic ingredients"
	quest.BA0000000000001F.title: "Tentacles"
	quest.BA00000000000020.quest_desc: ["Ocean's Delight adds exotic seafood. Guardian Soup is a placeable feast block."]
	quest.BA00000000000020.quest_subtitle: "Treasures of the deep"
	quest.BA00000000000020.title: "Seafood Feast"
	quest.BA00000000000021.quest_desc: ["You've mastered cooking. Now master the art of making a house a home. Chipped, Macaw's, Create Furnitures, and backpack logistics await."]
	quest.BA00000000000021.quest_subtitle: "Decoration mastery unlocked"
	quest.BA00000000000021.title: "Rank: Interior Designer"
	quest.BA00000000000022.quest_desc: ["The Carpenter's Table turns vanilla wood blocks into dozens of decorative variants."]
	quest.BA00000000000022.quest_subtitle: "Woodworking mastery"
	quest.BA00000000000022.title: "Carpenter's Table"
	quest.BA00000000000023.quest_desc: ["Hundreds of stone/brick variants. Every vanilla block gets 20+ decorative options."]
	quest.BA00000000000023.quest_subtitle: "Stone aesthetics"
	quest.BA00000000000023.title: "Mason Table"
	quest.BA00000000000024.quest_desc: ["Carpenter, Mason, Botanist, Loom, Tinkering, Alchemy — you have them all."]
	quest.BA00000000000024.quest_subtitle: "Place all 6 Chipped workstations"
	quest.BA00000000000024.title: "All Workstations"
	quest.BA00000000000025.quest_desc: ["Right-click windows with the hammer to change shape. Key locks them shut."]
	quest.BA00000000000025.quest_subtitle: "Let the light in"
	quest.BA00000000000025.title: "Window Hammer"
	quest.BA00000000000026.quest_desc: ["Macaw's Doors and Create Deco add dozens of door styles. From rustic barn doors to reinforced metal."]
	quest.BA00000000000026.quest_subtitle: "First impressions matter"
	quest.BA00000000000026.title: "Fancy Doors"
	quest.BA00000000000027.quest_desc: ["Macaw's Fences add decorative fence and gate options in many styles."]
	quest.BA00000000000027.quest_subtitle: "Define your borders"
	quest.BA00000000000027.title: "Fences & Gates"
	quest.BA00000000000028.quest_desc: ["Macaw's Trapdoors add decorative trapdoor options for floors and ceilings."]
	quest.BA00000000000028.quest_subtitle: "Hidden passages"
	quest.BA00000000000028.title: "Trapdoors"
	quest.BA00000000000029.quest_desc: ["Create Furnitures adds chairs, tables, and pillars in Create's style. Place some furniture — comfort matters even during wartime."]
	quest.BA00000000000029.quest_subtitle: "A house becomes a home"
	quest.BA00000000000029.title: "Chairs & Tables"
	quest.BA0000000000002A.quest_desc: ["Pillars add vertical decoration to your builds. Available in multiple Create metal styles."]
	quest.BA0000000000002A.quest_subtitle: "Architectural columns"
	quest.BA0000000000002A.title: "Pillars"
	quest.BA0000000000002B.quest_desc: ["Industrial decoration — catwalks, metal bars, cage lamps, coin stacks."]
	quest.BA0000000000002B.quest_subtitle: "Industrial aesthetics"
	quest.BA0000000000002B.title: "Create Deco"
	quest.BA0000000000002C.quest_desc: ["The Feeding Upgrade auto-eats food from your backpack when hungry. Your team never goes hungry again."]
	quest.BA0000000000002C.quest_subtitle: "Auto-feed from backpack"
	quest.BA0000000000002C.title: "Feeding Upgrade"
	quest.BA0000000000002D.quest_desc: ["Auto-applies potion effects from your backpack. Combined with your cooking, you keep the whole team buffed."]
	quest.BA0000000000002D.quest_subtitle: "Auto-apply buffs"
	quest.BA0000000000002D.title: "Alchemy Upgrade"
	quest.BA0000000000002E.quest_desc: ["Inception Upgrade = backpacks in backpacks. Infinite portable storage."]
	quest.BA0000000000002E.quest_subtitle: "Portable everything"
	quest.BA0000000000002E.title: "Diamond Backpack"
	quest.BA0000000000002F.quest_desc: ["Canvas rugs and tatami mats add floor decoration to your home."]
	quest.BA0000000000002F.quest_subtitle: "Floor coverings"
	quest.BA0000000000002F.title: "Canvas Rug"
	quest.BA00000000000030.quest_desc: ["Canvas signs let you label areas of your base with style."]
	quest.BA00000000000030.quest_subtitle: "Label your rooms"
	quest.BA00000000000030.title: "Canvas Signs"
	quest.BA00000000000031.quest_desc: ["Place decorative sourcestone variants for a magical aesthetic."]
	quest.BA00000000000031.quest_subtitle: "Arcane decoration"
	quest.BA00000000000031.title: "Sourcestone Deco"
	quest.BA00000000000032.quest_desc: ["You are the Matriarch. Automated cooking, team support, and gingerbread architecture await."]
	quest.BA00000000000032.quest_subtitle: "Domestic mastery"
	quest.BA00000000000032.title: "Rank: Matriarch"
	quest.BA00000000000033.quest_desc: ["Use Create machines to auto-produce chocolates and candies. A steady supply of combat buffs for your entire team."]
	quest.BA00000000000033.quest_subtitle: "Automated confectionery"
	quest.BA00000000000033.title: "Candy Factory"
	quest.BA00000000000034.quest_desc: ["Build an entire house from gingerbread. It gives Resistance when eaten. Edible walls."]
	quest.BA00000000000034.quest_subtitle: "Edible architecture"
	quest.BA00000000000034.title: "Gingerbread Architecture"
	quest.BA00000000000035.quest_desc: [
		"Steak & Potatoes (Nourishment), Hot Chocolate (Regen), Wine (Resistance), Dark Chocolate (Stimulation), Gingerbread (Resistance)."
		""
		"Stock 5 different foods with combat buffs."
	]
	quest.BA00000000000035.quest_subtitle: "5 combat-buff foods"
	quest.BA00000000000035.title: "Potion Meals"
	quest.BA00000000000036.quest_desc: ["Indestructible backpack. Everlasting Upgrade makes it survive death."]
	quest.BA00000000000036.quest_subtitle: "Indestructible storage"
	quest.BA00000000000036.title: "Netherite Backpack"
	quest.BA00000000000037.quest_desc: ["Your backpack auto-feeds you the best food and auto-applies potions. Walking buff machine."]
	quest.BA00000000000037.quest_subtitle: "Walking buff machine"
	quest.BA00000000000037.title: "Team Supply Kit"
	quest.BA00000000000038.quest_desc: ["Place 5 different feast blocks in your base. Your dining hall becomes the envy of every empire."]
	quest.BA00000000000038.quest_subtitle: "A table fit for royalty"
	quest.BA00000000000038.title: "The Grand Feast"
	quest.BA00000000000039.quest_desc: ["Produce every type of Farmer's Delight feast: Roast Chicken, Honey Glazed Ham, Shepherd's Pie, Stuffed Pumpkin, Rice Roll Medley, Gleaming Salad, Apple Pie, Sweet Berry Cheesecake, Chocolate Pie."]
	quest.BA00000000000039.quest_subtitle: "Every feast mastered"
	quest.BA00000000000039.title: "Feast Master"
	quest.BA0000000000003A.quest_desc: [
		"A kitchen behind SecurityCraft cameras and reinforced walls is a kitchen that stays running during a siege. Fighters retreat behind the walls, eat a feast, and go back out."
		""
		"Solo: you'd need to learn SecurityCraft camera and reinforcement systems. With a Military teammate: they set up the perimeter. You set up the kitchen inside it."
	]
	quest.BA0000000000003A.quest_subtitle: "Safe behind the walls"
	quest.BA0000000000003A.title: "War Kitchen"
	quest.BA0000000000003B.quest_desc: [
		"A fully decorated base with Chipped blocks, Macaw's windows and doors, Create furniture, and an automated kitchen. Your home is a fortress of comfort — and your team has never been better fed."
		""
		"The empire may have warriors and engineers, but it runs on your cooking."
	]
	quest.BA0000000000003B.quest_subtitle: "The heart of the empire"
	quest.BA0000000000003B.title: "Domestic Supremacy"
