	quest.393F4F98D2790508.title: "Alchemical Supremacy"
	quest.394123C7AF68358A.quest_desc: ["The Enrichment Chamber transmutes raw ore into purified forms, doubling your yield. The foundation of all alchemy."]
	quest.394123C7AF68358A.quest_subtitle: "The first transmutation"
	quest.394123C7AF68358A.title: "Ore Doubling"
	quest.39545E7E38DDFA90.quest_desc: ["Start farming. Here are seeds for everything — plant them all."]
	quest.39545E7E38DDFA90.quest_subtitle: "Start farming"
	quest.39545E7E38DDFA90.title: "Green Thumb"
	quest.3A27854AA0D3773D.quest_desc: [
		"The ultimate food automation: AE2 requests ingredients, Create machines process them through Farmer's Delight recipes, finished meals return to storage."
		""
		"Solo: you'd need to learn both cooking and factory automation. With a Housewife + Engineering teammate: one provides the recipes, the other the machines. You wire it all together."
	]
	quest.3A27854AA0D3773D.quest_subtitle: "The kitchen never sleeps"
	quest.3A27854AA0D3773D.title: "Automated Kitchen"
	quest.3ADD6AEC02F8BEAF.quest_desc: ["Each glyph adds a new ability to your spells. Combine them creatively — the spell system is incredibly flexible."]
	quest.3ADD6AEC02F8BEAF.quest_subtitle: "Expand your repertoire"
	quest.3ADD6AEC02F8BEAF.title: "Glyph Collection"
	quest.3AF0E817D4F6E719.quest_desc: [
		"7 parallel slots. Industrial-scale"
		"transmutation."
	]
	quest.3AF0E817D4F6E719.title: "Elite Factory"
	quest.3B8AA671D97E0F01.quest_desc: ["Mekanism powers the path of Alchemy — ore transmutation, power generation, and eventually nuclear transformation. Here's a head start."]
	quest.3B8AA671D97E0F01.quest_subtitle: "Transmutation begins"
	quest.3BD3ACAB51091AFD.title: "Fusion Reactor Frame"
	quest.3C0ED3DC31B502CE.quest_desc: ["Effect glyph — teleports you forward. Self + Blink = instant teleport. Essential mobility spell."]
	quest.3C0ED3DC31B502CE.title: "Glyph: Blink"
	quest.3C99B7015244CFD8.quest_desc: ["A separate spell system focused on combat. Iron's Spells uses discovered scrolls and structured spell classes."]
