	quest.37C2916A1DBFE0D7.title: "Infused Alloy"
	quest.3841E77706FC82FD.quest_desc: ["The ultimate weapon — nuclear devastation."]
	quest.3841E77706FC82FD.quest_subtitle: "Mutually assured destruction"
	quest.3841E77706FC82FD.title: "Nuclear Arsenal"
