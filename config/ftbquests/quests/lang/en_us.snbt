	quest.4CCD46675CF3B785.quest_desc: ["Applied Energistics 2 stores thousands of items digitally. Here's a full starter system — place the controller, drives, and terminal."]
	quest.4CCD46675CF3B785.quest_subtitle: "Infinite storage capacity"
	quest.4CCD46675CF3B785.title: "Digital Storage"
	quest.4CF2E84BE4519251.quest_desc: ["Find iron and smelt it. Here's a full set to get you going — you won't need to mine iron for a while."]
	quest.4CF2E84BE4519251.quest_subtitle: "The foundation of civilization"
	quest.4D1B274D420E585B.quest_desc: [
		"Funnels insert/extract items."
		"Andesite = simple. Brass = filtered."
	]
