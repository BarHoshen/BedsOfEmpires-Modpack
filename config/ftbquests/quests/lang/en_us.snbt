	quest.341E83D90E7449FA.title: "Glyph: Intangible"
	quest.36DCF673F1BE4033.quest_desc: ["Effect glyph — creates a light source where it hits. Useful for cave exploration."]
	quest.36DCF673F1BE4033.title: "Glyph: Light"
	quest.36FC554BA8A349FF.quest_desc: ["Fusion is the pinnacle of nuclear alchemy. Combining atoms to create energy — you have forged a miniature star."]
