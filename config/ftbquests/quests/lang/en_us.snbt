	quest.680D2C16C5C6B7B9.title: "Wixie"
	quest.6892651C7FDC2A86.quest_desc: ["Mines explode when stepped on. Place them around your perimeter."]
	quest.6892651C7FDC2A86.quest_subtitle: "Watch your step"
	quest.6892651C7FDC2A86.title: "Minefield"
	quest.68A0831F507A96FF.quest_desc: ["Ars Nouveau lets you design custom spells from modular glyphs. Source gems power everything. Let's begin."]
	quest.68A0831F507A96FF.quest_subtitle: "Master the arcane arts"
	quest.68A0831F507A96FF.title: "Welcome to Magic"
	quest.69BB2444E382CC02.quest_desc: [
		"Your scout has copied the enemy base layout with the Copy Paste Gadget. Now you know where their bed is, where the mines are, and where the walls are weakest."
		""
		"Solo: you'd need to craft Building Gadgets and risk scouting yourself. With a Scout teammate: they bring back the template. You plan the artillery strike."
	]
	quest.69BB2444E382CC02.quest_subtitle: "Intel wins wars"
	quest.69BB2444E382CC02.title: "Pre-Strike Briefing"
	quest.69C0E6BFA704FF9C.quest_desc: ["Train network with 3+ stations connecting different locations."]
	quest.69C0E6BFA704FF9C.quest_subtitle: "Logistics Master"
	quest.69CCC481B6C9C907.quest_desc: ["Belts move items between machines. Funnels insert and extract. This is the backbone of every factory."]
	quest.69CCC481B6C9C907.quest_subtitle: "Move items automatically"
	quest.6C15243D914FF425.quest_desc: ["Effect glyph — sets targets on fire. Projectile + Ignite + AOE = fire bombardment."]
	quest.6C15243D914FF425.title: "Glyph: Ignite"
	quest.6C37303CCD775B1D.quest_desc: ["The Scribe's Table is where you learn glyphs and inscribe spell parchments."]
	quest.6C37303CCD775B1D.title: "Scribe's Table"
	quest.6C640C2D8CC3F6C4.quest_desc: ["Mirrorweave copies the appearance of adjacent blocks. Disguise your defenses."]
	quest.6C640C2D8CC3F6C4.title: "Mirrorweave"
	quest.6C6FE7CDFB356149.quest_desc: ["Steam engines provide massive SU. Combined with blaze burners, your factory can power anything."]
	quest.6C6FE7CDFB356149.quest_subtitle: "Industrial revolution"
	quest.6D9C6CB2540F80EA.quest_desc: [
		"Apotheosis gems add raw stat bonuses to socketed gear — including magical weapons. A socketed Archmage staff with combat gems is devastating."
		""
		"Solo: you'd need to grind Apotheosis content, fight bosses, and level gem cutting. With a Scout teammate: they have Sigils of Socketing and gems from their dungeon runs. Trade magic for intel."
	]
	quest.6D9C6CB2540F80EA.quest_subtitle: "Gems meet magic"
	quest.6D9C6CB2540F80EA.title: "Gem-Socketed Staves"
	quest.6DA40C5A37BC9F42.quest_desc: ["Trains transport items and players across long distances. Connect your base to resource outposts."]
	quest.6DA40C5A37BC9F42.quest_subtitle: "All aboard"
	quest.6DB17A86EDE1E5AC.quest_desc: [
		"Converts steam from fission into"
		"massive FE. The power multiplier."
	]
	quest.6DB17A86EDE1E5AC.title: "Turbine"
	quest.6DE0E5DBAB088EC7.quest_desc: [
		"Factories process 3+ items at once."
		"The multiplier for everything."
	]
	quest.6DE0E5DBAB088EC7.title: "Basic Factory"
	quest.6E9E28B414BCF083.quest_desc: [
		"Every automated base has a single point of failure: its power source. Find their generators, chunk loaders, or source jars and destroy them."
		""
		"Without power, their machines stop. Without chunk loading, their farms die. Without source, their turrets go silent. One scout can cripple an empire."
	]
	quest.6E9E28B414BCF083.quest_subtitle: "Kill their infrastructure"
	quest.6E9E28B414BCF083.title: "Sabotage: Power Cut"
	quest.6F14222ED362F948.quest_desc: ["A layered defense. Multiple trap types means an attacker can't prepare for just one."]
	quest.6F14222ED362F948.quest_subtitle: "Layered defenses"
	quest.6F14222ED362F948.title: "Trap Master"
	quest.6F179A7603263F34.quest_desc: ["Applies your Touch spell before dealing damage. Magic-enhanced melee."]
	quest.6F179A7603263F34.title: "Enchanter's Sword"
	quest.6F638A64502E4CBA.quest_desc: ["Effect glyph — undoes recent damage or position changes. A second chance in combat."]
	quest.6F638A64502E4CBA.title: "Glyph: Rewind"
	quest.6FAD48362241427F.quest_desc: ["The Alternator converts Create's rotational force (SU) into Forge Energy (FE). This bridges Create with Mekanism — your windmills can now power laser turrets."]
	quest.6FAD48362241427F.quest_subtitle: "SU meets FE"
	quest.6FF4EE2E3FAA74B9.quest_desc: [
		"Your first nuclear reactor. Generates"
		"massive power. Careful — meltdowns are possible."
		"Monitor the temperature."
	]
	quest.6FF4EE2E3FAA74B9.title: "Fission Reactor"
	quest.701ADC68A78CF7CF.quest_desc: ["Your first Cataclysm boss. These fights are brutal but the drops are weapons that no amount of crafting can match. Bring potions, food, and your best gear."]
	quest.701ADC68A78CF7CF.quest_subtitle: "Claim a legend's weapon"
	quest.701ADC68A78CF7CF.title: "First Boss Kill"
	quest.70668B9BAA33017B.quest_desc: [
		"Burns fuel for FE. Cheap power"
		"from lava or coal."
	]
	quest.70668B9BAA33017B.title: "Heat Generator"
	quest.70A4C043E72D9B43.quest_desc: ["Brass unlocks the advanced tier of Create machines. You should be producing this automatically by now."]
	quest.70A4C043E72D9B43.quest_subtitle: "Advanced alloys"
	quest.70C196302FC03283.quest_desc: [
		"Configurable area (1x1 to 5x5 chunks)."
		"Works on trains and moving contraptions!"
	]
	quest.70CC5B0694DB44BB.title: "World Tier: Summit"
	quest.70FEF19DA1FD4700.quest_desc: [
		"Quadruples ore output. The ultimate"
		"ore processing chain: 5x ore multiplication."
	]
	quest.70FEF19DA1FD4700.title: "Chemical Injection Chamber"
	quest.71FE6A5A12389C41.quest_desc: [
		"Now that you've scouted their base, it's time for sabotage. Plant mines along paths they use — entrances, corridors near their bed, around their storage."
		""
		"Requires knowledge from the Military path's Minefield quest. You need to know your explosives."
	]
	quest.71FE6A5A12389C41.quest_subtitle: "Leave surprises behind"
	quest.71FE6A5A12389C41.title: "Sabotage: Minelayer"
	quest.72CA09443AFDCFF3.quest_desc: [
		"Stronger enemies, better loot."
		"Apothic Invaders drop affix gear."
	]
	quest.72CA09443AFDCFF3.title: "World Tier: Ascent"
	quest.72CEC170B47AC569.quest_desc: [
		"Stores FE. Buffer between generators"
		"and machines."
	]
	quest.72CEC170B47AC569.title: "Energy Cube"
	quest.7357863DBDAB1065.quest_desc: ["Summon the Chimera using the Ritual of Summon Wilden with Horn + Wing + Spike on the pedestal. This is the hardest Ars Nouveau fight."]
	quest.7357863DBDAB1065.title: "Wilden Hunt"
	quest.737D35C31391BB26.quest_desc: [
		"Fusion Reactor + Digital Miner +"
		"AE2 autocrafting + Mekanism lasers all running."
		"All paths of alchemy converge."
	]
	quest.737D35C31391BB26.title: "The Philosopher's Stone"
	quest.739DAA3454F9C554.quest_desc: ["Ars Elemental adds elemental specialization. Each element enhances specific glyph types."]
	quest.739DAA3454F9C554.title: "Elemental Focus"
	quest.73BAA8AF2ACD5602.quest_desc: [
		"Drones scout, mine, and haul"
		"autonomously. Equip modules and deploy."
	]
	quest.750903BB997EE8F5.quest_desc: [
		"Converts gas to fluid and back. Essential for"
		"many advanced recipes."
	]
	quest.750903BB997EE8F5.title: "Rotary Condensentrator"
	quest.75A6CD149A4CC9C4.quest_desc: ["The archmage spell book holds more glyphs and casts more powerfully. You're now a serious combat threat."]
	quest.75A6CD149A4CC9C4.quest_subtitle: "The ultimate spell book"
	quest.75A6CD149A4CC9C4.title: "Archmage's Book"
	quest.769E3641D5B062DD.quest_desc: ["Your first nuclear reactor. The alchemist's dream — splitting atoms to release their energy. Requires careful management — meltdowns are possible."]
	quest.769E3641D5B062DD.quest_subtitle: "Split the atom"
	quest.769E3641D5B062DD.title: "Fission Reactor"
	quest.76C5EF95FF85BA05.title: "Laser Focus Matrix"
	quest.770C0D95C02F0DD4.quest_desc: [
		"Automated enchanting. Feed it items,"
		"lapis, and liquid XP — it enchants automatically."
	]
	quest.774B83503C7E956F.quest_desc: ["Create mod turns Minecraft into a factory simulator. Craft some andesite alloy — here's enough to build your first machines."]
	quest.774B83503C7E956F.quest_subtitle: "Gears and alloys"
	quest.779DE56CA7A17C11.quest_desc: ["Prevents hostile spawns in a 32-block radius. Your base is now safe from mobs."]
	quest.779DE56CA7A17C11.title: "Ritual: Sanctuary"
	quest.78011191A9F8AE5E.quest_desc: ["The Dominion Wand links machines, relays, and containers. Essential for automation."]
	quest.78011191A9F8AE5E.title: "Dominion Wand"
	quest.7930B17AC42C074D.quest_desc: ["Crushing wheels break down ores into more materials than a furnace. Double your ore output."]
	quest.7930B17AC42C074D.quest_subtitle: "Double your ores"
	quest.7998AA438690842E.quest_desc: ["{image: width:100 height:100 align:center}"]
	quest.7998AA438690842E.quest_subtitle: "Choose this if you prefer using weapons to defend your bed"
	quest.79E6D38509D371BB.title: "Ultimate Control Circuit"
	quest.7A2624473807242D.quest_desc: ["Mixers combine materials in basins. You'll need this for brass and many advanced recipes."]
	quest.7A2624473807242D.quest_subtitle: "Combine and alloy"
	quest.7AA7E0FE5747BDEC.quest_desc: [
		"Motors convert electricity to rotation"
		"at scale. More efficient than alternator chains."
	]
	quest.7AD62BEFA25BF6A3.quest_desc: ["Fully automated resource pipeline: Mystical Ag farm → Create processing → AE2 storage, all without manual input."]
	quest.7AD62BEFA25BF6A3.quest_subtitle: "Tycoon"
	quest.7AD62BEFA25BF6A3.title: "Self-Sustaining Empire"
	quest.7B0965038BCE0203.quest_desc: [
		"The pinnacle of nuclear alchemy."
		"Fusing atoms = essentially unlimited energy."
	]
	quest.7B0965038BCE0203.title: "Thermonuclear Fusion"
	quest.7B2C24B72475FA3A.quest_desc: ["The strongest conventional armor. A direct sword hit barely scratches you. But cannons still hurt."]
	quest.7B2C24B72475FA3A.quest_subtitle: "Nearly impervious"
	quest.7B2C24B72475FA3A.title: "Refined Obsidian"
	quest.7B7407D6C493A749.quest_desc: ["Different meals give different buffs. A well-fed army fights better."]
	quest.7B7407D6C493A749.quest_subtitle: "10 different meals"
	quest.7B7407D6C493A749.title: "Gourmet Kitchen"
	quest.7C1164F01C503F4C.quest_desc: ["Golems attack hostile mobs and enemy players. Your first automated defenders."]
	quest.7C1164F01C503F4C.quest_subtitle: "Automated guardians"
	quest.7C1164F01C503F4C.title: "Iron Defenders"
	quest.7C2198B9541727D9.quest_desc: ["Augment glyph — makes spells hit in an area instead of a single target. Projectile + Snare + AOE = crowd control."]
	quest.7C2198B9541727D9.title: "Glyph: AOE"
	quest.7C6A764DC6BEC38A.quest_desc: ["Mithril armor enhances spell power and provides strong physical protection."]
	quest.7C6A764DC6BEC38A.title: "Mithril Armor"
	quest.7CD36012D4823E37.quest_desc: [
		"Copies enchanted books, written books,"
		"and train schedules. Mass-produce enchantments."
	]
	quest.7DE1081F8383601D.title: "Fission Reactor Casing"
	quest.7EEDBFDEA27616E2.quest_desc: [
		"Programmable redstone sequences."
		"Automate complex timing systems."
	]
	quest.7EF882C3253B0AF6.quest_desc: ["Rituals provide powerful area effects — flight, warding, mob spawning suppression."]
	quest.7EF882C3253B0AF6.quest_subtitle: "Master of rituals"
	quest.7EF882C3253B0AF6.title: "Ritual Master"
	quest.7F073BEB3B5D2F41.quest_desc: ["Laser grids detect anything that passes through. Connect to alarms or traps."]
	quest.7F073BEB3B5D2F41.quest_subtitle: "Invisible tripwires"
	quest.7F073BEB3B5D2F41.title: "Laser Perimeter"
	quest.7F1205D341C2EC5E.quest_desc: ["Mekanism lasers require FE power — which you get from the Engineering path's Electric Bridge. High-tech defense."]
	quest.7F1205D341C2EC5E.quest_subtitle: "High-tech defense"
	quest.7F1205D341C2EC5E.title: "Energy Weapons"
	quest.7F207B28D3DE39C4.title: "Advanced Control Circuit"
	quest.7F69479A6D1264EA.quest_desc: ["The world grows more dangerous and more rewarding."]
	quest.7F69479A6D1264EA.quest_subtitle: "Ascend further"
	quest.7F69479A6D1264EA.title: "World Tier: Ascent"
	quest.AD00000000000001.quest_desc: ["SecurityCraft protects what's yours. Reinforced blocks can't be broken by anyone but you. The manual explains everything — read it."]
	quest.AD00000000000001.quest_subtitle: "Your fortress begins here"
	quest.AD00000000000001.title: "Welcome to Military"
	quest.AD00000000000002.quest_desc: ["Right-click any block with the Universal Block Reinforcer to make it unbreakable by anyone but you. Your walls are now permanent."]
	quest.AD00000000000002.quest_subtitle: "Unbreakable walls"
	quest.AD00000000000002.title: "Reinforced Stone"
	quest.AD00000000000003.quest_desc: ["Lv2 reinforces a wider range of blocks and is more durable."]
	quest.AD00000000000003.quest_subtitle: "Better reinforcement"
	quest.AD00000000000003.title: "Universal Reinforcer Lv2"
	quest.AD00000000000004.quest_desc: ["Obsidian is already hard to break. Reinforced obsidian is impossible. Encase your bed."]
	quest.AD00000000000004.quest_subtitle: "Impenetrable defense"
	quest.AD00000000000004.title: "Reinforced Obsidian"
	quest.AD00000000000005.quest_desc: ["Step on it, it explodes. Disguised as the block they're placed on."]
	quest.AD00000000000005.quest_subtitle: "Watch your step"
	quest.AD00000000000005.title: "Minefield"
	quest.AD00000000000006.quest_desc: ["Zaps anyone who touches it. Line your perimeter with pain."]
	quest.AD00000000000006.quest_subtitle: "Electrified perimeter"
	quest.AD00000000000006.title: "Electrified Fence"
	quest.AD00000000000007.quest_desc: ["Detects nearby players and entities. Your early warning system."]
	quest.AD00000000000007.quest_subtitle: "Early warning system"
	quest.AD00000000000007.title: "Portable Radar"
	quest.AD00000000000008.quest_desc: ["Directional explosive. Place facing a corridor — anything that walks through gets hit."]
	quest.AD00000000000008.quest_subtitle: "Directional death"
	quest.AD00000000000008.title: "Claymore"
	quest.AD00000000000009.quest_desc: ["Lights up when something moves nearby. Cheap, effective, spooky for intruders."]
	quest.AD00000000000009.quest_subtitle: "Motion detection"
	quest.AD00000000000009.title: "Motion Light"
	quest.AD0000000000000A.quest_desc: ["Logs the name of anyone who walks past. Now you know WHO was snooping."]
	quest.AD0000000000000A.quest_subtitle: "Know your intruders"
	quest.AD0000000000000A.title: "Username Logger"
	quest.AD0000000000000B.quest_desc: ["Alarms blare when triggered by redstone. Connect to cameras or lasers for auto-alerts."]
	quest.AD0000000000000B.quest_subtitle: "Sound the alarm"
	quest.AD0000000000000B.title: "Alarm"
	quest.AD0000000000000C.quest_desc: ["Pops up before exploding. Larger blast radius than a basic mine."]
	quest.AD0000000000000C.quest_subtitle: "Bigger boom"
	quest.AD0000000000000C.title: "Bouncing Betty"
	quest.AD0000000000000D.quest_desc: ["Cameras let you watch your perimeter remotely. Right-click the monitor to cycle views."]
	quest.AD0000000000000D.quest_subtitle: "Eyes everywhere"
	quest.AD0000000000000D.title: "Surveillance State"
	quest.AD0000000000000E.quest_desc: ["Intelligent Munitions System. Launches guided explosive projectiles at nearby players. The smart mine."]
	quest.AD0000000000000E.quest_subtitle: "Smart explosives"
	quest.AD0000000000000E.title: "IMS"
	quest.AD0000000000000F.quest_desc: ["Drops a cage on intruders, trapping them in place. Capture, don't kill."]
	quest.AD0000000000000F.quest_subtitle: "Capture intruders"
	quest.AD0000000000000F.title: "Cage Trap"
	quest.AD00000000000010.quest_desc: ["Your base has cameras, mines, and reinforced walls. Now it's time for laser grids, automated turrets, and access control."]
	quest.AD00000000000010.quest_subtitle: "Advanced security"
	quest.AD00000000000010.title: "Rank: Commander"
	quest.AD00000000000011.quest_desc: ["Laser grids between two blocks detect anything that passes through."]
	quest.AD00000000000011.quest_subtitle: "Invisible tripwires"
	quest.AD00000000000011.title: "Laser Block"
	quest.AD00000000000012.quest_desc: ["Stronger than diamond. You need Mekanism processing for osmium — or ask an Alchemy teammate for ingots."]
	quest.AD00000000000012.quest_subtitle: "Superior protection"
	quest.AD00000000000012.title: "Armored Up"
	quest.AD00000000000013.quest_desc: ["Scans players' inventories as they pass. Detect stolen goods or contraband."]
	quest.AD00000000000013.quest_subtitle: "Scan for contraband"
	quest.AD00000000000013.title: "Inventory Scanner"
	quest.AD00000000000014.quest_desc: ["Alerts you when any block in an area is placed or broken. Anti-sabotage."]
	quest.AD00000000000014.quest_subtitle: "Anti-sabotage"
	quest.AD00000000000014.title: "Block Change Detector"
	quest.AD00000000000015.quest_desc: ["Looks like a normal floor. Step on it and fall into whatever's below."]
	quest.AD00000000000015.quest_subtitle: "Hidden pitfall"
	quest.AD00000000000015.title: "Floor Trap"
	quest.AD00000000000016.quest_desc: ["Lock your doors with a passcode. Only those who know it can enter."]
	quest.AD00000000000016.quest_subtitle: "Secure access"
	quest.AD00000000000016.title: "Keypad Door"
	quest.AD00000000000017.quest_desc: ["Password-protected storage. Even if someone gets in, they can't open your chests."]
	quest.AD00000000000017.quest_subtitle: "Locked storage"
	quest.AD00000000000017.title: "Keypad Chest"
	quest.AD00000000000018.quest_desc: ["Only YOU can open this door. Uses biometric scanning — no password to crack."]
	quest.AD00000000000018.quest_subtitle: "Biometric lock"
	quest.AD00000000000018.title: "Retinal Scanner"
	quest.AD00000000000019.quest_desc: ["5 keycard levels. Give teammates low-level cards, keep high-level for yourself."]
	quest.AD00000000000019.quest_subtitle: "Tiered clearance"
	quest.AD00000000000019.title: "Keycard System"
	quest.AD0000000000001A.quest_desc: ["Cracks keypads and passwords. Useful when raiding enemy bases."]
	quest.AD0000000000001A.quest_subtitle: "Hack enemy locks"
	quest.AD0000000000001A.title: "Codebreaker"
	quest.AD0000000000001B.quest_desc: ["Automated turrets that shoot hostile mobs and non-whitelisted players. Add a whitelist module to spare your teammates."]
	quest.AD0000000000001B.quest_subtitle: "Automated turrets"
	quest.AD0000000000001B.title: "Sentry"
	quest.AD0000000000001C.quest_desc: ["Destroys incoming projectiles — arrows, fireballs, cannon shells. Anti-air defense."]
	quest.AD0000000000001C.quest_subtitle: "Anti-projectile defense"
	quest.AD0000000000001C.title: "Trophy System"
	quest.AD0000000000001D.quest_desc: ["A block that hurts anyone who gets close. Place around valuable areas."]
	quest.AD0000000000001D.quest_subtitle: "Pain field"
	quest.AD0000000000001D.title: "Protecto"
	quest.AD0000000000001E.quest_desc: ["The strongest conventional armor. Sword hits barely scratch you. But cannons still hurt."]
	quest.AD0000000000001E.quest_subtitle: "Nearly impervious"
	quest.AD0000000000001E.title: "Refined Obsidian Armor"
	quest.AD0000000000001F.quest_desc: ["Projectors disguise blocks as other blocks. Make your base look like terrain."]
	quest.AD0000000000001F.quest_subtitle: "Disguise your base"
	quest.AD0000000000001F.title: "Projector"
	quest.AD00000000000020.quest_desc: ["Fake water and lava that don't flow. Confuse raiders."]
	quest.AD00000000000020.quest_subtitle: "Deceptive fluids"
	quest.AD00000000000020.title: "Fake Water/Lava"
	quest.AD00000000000021.quest_desc: ["Signs only you can read. Leave fake directions for enemies."]
	quest.AD00000000000021.quest_subtitle: "Invisible messages"
	quest.AD00000000000021.title: "Secret Signs"
	quest.AD00000000000022.quest_desc: ["Your base is a fortress. Now it's time to build weapons that can break OTHER fortresses."]
	quest.AD00000000000022.quest_subtitle: "Build the big guns"
	quest.AD00000000000022.title: "Rank: General"
	quest.AD00000000000023.quest_desc: ["Cannons are cast from molten metal. Pour metal into moulds, then bore the barrel."]
	quest.AD00000000000023.quest_subtitle: "Cast your first cannon"
	quest.AD00000000000023.title: "Cannon Casting"
	quest.AD00000000000024.quest_desc: ["Your first cannon barrel. Cast iron is cheap and effective for basic artillery."]
	quest.AD00000000000024.quest_subtitle: "Basic artillery"
	quest.AD00000000000024.title: "Cast Iron Cannon"
	quest.AD00000000000025.quest_desc: ["Bores unbored cannon blocks into usable barrels. Requires Create rotation."]
	quest.AD00000000000025.quest_subtitle: "Bore the barrel"
	quest.AD00000000000025.title: "Cannon Drill"
	quest.AD00000000000026.quest_desc: ["Mount your cannon on a platform. The yaw controller aims it with Create gears."]
	quest.AD00000000000026.quest_subtitle: "Aim and fire"
	quest.AD00000000000026.title: "Cannon Mount"
	quest.AD00000000000028.quest_desc: ["Load propellant, load shot, light it. The ground game just changed."]
	quest.AD00000000000028.quest_subtitle: "The ground shakes"
	quest.AD00000000000028.title: "Artillery"
	quest.AD00000000000029.quest_desc: ["Bronze is stronger than cast iron. Longer range, more shots before breaking."]
	quest.AD00000000000029.quest_subtitle: "Stronger metal"
	quest.AD00000000000029.title: "Bronze Cannon"
	quest.AD0000000000002A.quest_desc: ["Steel cannons are the standard for serious warfare. Screw breeches for fast reload."]
	quest.AD0000000000002A.quest_subtitle: "Standard warfare"
	quest.AD0000000000002A.title: "Steel Cannon"
	quest.AD0000000000002B.quest_desc: ["The screw breech is the fastest reloading mechanism. Essential for sustained fire."]
	quest.AD0000000000002B.quest_subtitle: "Rapid reload"
	quest.AD0000000000002B.title: "Steel Screw Breech"
	quest.AD0000000000002C.quest_desc: ["Basic kinetic ammunition. Gets the job done."]
	quest.AD0000000000002C.quest_subtitle: "Basic ammunition"
	quest.AD0000000000002C.title: "Solid Shot"
	quest.AD0000000000002D.quest_desc: ["Armor Piercing. Goes through reinforced walls."]
	quest.AD0000000000002D.quest_subtitle: "Pierce armor"
	quest.AD0000000000002D.title: "AP Shot"
	quest.AD0000000000002E.quest_desc: ["High Explosive. Bigger boom than TNT. Add a fuze to control detonation."]
	quest.AD0000000000002E.quest_subtitle: "Bigger boom"
	quest.AD0000000000002E.title: "HE Shell"
	quest.AD0000000000002F.quest_desc: ["Fuzes control when shells explode. Proximity for anti-air, timed for airburst, delayed for bunker busting."]
	quest.AD0000000000002F.quest_subtitle: "Control the detonation"
	quest.AD0000000000002F.title: "Fuze Workshop"
	quest.AD00000000000030.quest_desc: ["Automates loading. Combine with Create belts for continuous fire."]
	quest.AD00000000000030.quest_subtitle: "Automated ammunition"
	quest.AD00000000000030.title: "Cannon Loader"
	quest.AD00000000000032.quest_desc: ["Mekanism lasers need FE power from the Engineering path's Electric Bridge."]
	quest.AD00000000000032.quest_subtitle: "High-tech defense"
	quest.AD00000000000032.title: "Energy Weapons"
	quest.AD00000000000033.quest_desc: ["Wide area anti-personnel. Better for base defense and open-field combat."]
