		"Deployers right-click or place items."
		"Essential for sequenced assembly lines."
	]
	quest.31C490E5EB846875.quest_desc: ["Storage Drawers hold massive amounts of single items. The controller lets you insert into the nearest available drawer."]
	quest.31C490E5EB846875.quest_subtitle: "Drawers for everything"
	quest.31C490E5EB846875.title: "Organized Storage"
	quest.31E9E1A12968D5E9.title: "Chemical Infuser"
	quest.325F75787A8A0BAD.quest_desc: ["Destroy an enemy player's bed."]
	quest.325F75787A8A0BAD.quest_subtitle: "Conqueror"
	quest.325F75787A8A0BAD.title: "Bed Destroyer"
