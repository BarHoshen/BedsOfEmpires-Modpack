	quest.3D217C2A33395328.title: "Rank: Transmuter"
	quest.3D247E0B1F841AB0.title: "Module: Vein Mining"
	quest.3DB61D3786431F47.quest_desc: ["The highest tier of Mystical Agriculture. You can now grow anything — diamonds, netherite, anything."]
	quest.3DB61D3786431F47.quest_subtitle: "The highest tier"
	quest.3DB61D3786431F47.title: "Supremium Harvest"
	quest.3DF935A1F39B42EC.quest_desc: ["Sophisticated Backpacks with upgrades make raiding and exploring much easier. Auto-pickup, auto-feed, magnet."]
	quest.3DF935A1F39B42EC.quest_subtitle: "Portable storage"
	quest.3DF935A1F39B42EC.title: "Backpack Logistics"
	quest.3E135195BF6EA70D.quest_desc: [
		"Airships, nuclear power, drones, and"
		"jetpacks. You've mastered every form of engineering."
	]
	quest.3EC41F48ACF96C95.quest_desc: ["Osmium armor is stronger than diamond. You can now survive a direct fight with a geared player."]
	quest.3EC41F48ACF96C95.quest_subtitle: "Superior protection"
	quest.3EC41F48ACF96C95.title: "Armored Up"
	quest.3EC834C0E84133F5.quest_desc: ["Cataclysm dungeons contain bosses that drop weapons no factory can produce. Find one using the dungeon locator eyes — here's a few to get started."]
	quest.3EC834C0E84133F5.quest_subtitle: "Enter the depths"
	quest.3EC834C0E84133F5.title: "Dungeon Diver"
	quest.3F94744DF5A0E2B2.quest_desc: ["Fast player transport through tubes. Connect your base to outposts or defensive positions."]
	quest.3F94744DF5A0E2B2.quest_subtitle: "Fast travel"
	quest.3F9CB33F2E0F6087.quest_desc: ["Familiars fight alongside you and provide passive bonuses."]
	quest.3F9CB33F2E0F6087.quest_subtitle: "Summon a companion"
	quest.3F9CB33F2E0F6087.title: "Familiar Bond"
	quest.3FF9B807A689AE7C.quest_desc: ["The Steampunk armor set has built-in RADAR — you can detect nearby entities through walls. Essential for scouting enemy bases without being seen."]
	quest.3FF9B807A689AE7C.quest_subtitle: "See through walls"
	quest.3FF9B807A689AE7C.title: "Steampunk Scout"
	quest.402FF87B045D8E06.quest_desc: ["Find your first diamond. Here's a bunch more — you'll need them for enchanting and advanced recipes."]
	quest.402FF87B045D8E06.quest_subtitle: "A miner's dream"
	quest.41BC1643B03D6CB5.title: "Elite Control Circuit"
	quest.4201D5964FED7035.quest_desc: [
		"Mekanism alloys are a grind for"
		"engineers. An Alchemy teammate has surplus."
	]
	quest.42896156ABF87AFE.quest_desc: ["Ars Nouveau lets you craft custom spells. Here's a spell book and some source gems to start experimenting."]
	quest.42896156ABF87AFE.quest_subtitle: "Source and spells"
	quest.4326BB9DF2AF0956.quest_desc: ["The Digital Miner extracts specific ores from the ground automatically. The earth itself yields its treasures to the alchemist."]
	quest.4326BB9DF2AF0956.quest_subtitle: "Extract from the earth"
	quest.4326BB9DF2AF0956.title: "Digital Miner"
	quest.437A66285BFD2980.quest_desc: ["Set up a base near your game bed. Remember: you can't build within 6 blocks of your bed, so plan around it."]
	quest.437A66285BFD2980.quest_subtitle: "Settle down near your game bed"
	quest.449A48A2EE7F1983.quest_desc: ["Iron's Spells 'n Spellbooks adds combat-focused magic. Separate spell book, separate spell system — powerful for PvP."]
	quest.449A48A2EE7F1983.quest_subtitle: "Combat-focused magic"
	quest.449A48A2EE7F1983.title: "Iron's Spellcasting"
	quest.44EEA6ACC998DEA5.quest_desc: [
		"Moving stairs and walkways."
		"The civilized way to travel vertically."
	]
	quest.4513D22DF2C9CF92.quest_desc: ["Item transport between inventories. Give a wild Starbuncle a gold nugget for its token."]
	quest.4513D22DF2C9CF92.title: "Starbuncle"
	quest.451D06BCEFDBCC6B.title: "World Tier: Haven"
	quest.459554809B5A29DA.quest_desc: [
		"Mechanical crafters auto-craft recipes"
		"when connected in a grid. 3x3 = any recipe."
	]
	quest.45A858AE4F3026B7.quest_desc: ["Frontier tier means stronger enemies but much better loot. Apothic Invaders start spawning — powerful enemies with guaranteed affix item drops."]
	quest.45A858AE4F3026B7.quest_subtitle: "Danger and reward"
	quest.45A858AE4F3026B7.title: "World Tier: Frontier"
	quest.45F0E0FF27B8C1B9.quest_desc: [
		"Scout three different enemy bases and return alive each time. You know their layouts, their defenses, their weaknesses."
		""
		"Your team doesn't fight blind. Every battle they win started with your intel."
	]
	quest.45F0E0FF27B8C1B9.quest_subtitle: "No base is safe"
	quest.45F0E0FF27B8C1B9.title: "Deep Cover"
	quest.462447B71B1E89D0.quest_desc: ["Jars store liquid source. Place near your enchanting apparatus."]
	quest.462447B71B1E89D0.title: "Source Jar"
	quest.46F78DF81CCF11F2.quest_desc: [
		"Made via sequenced assembly — Create's"
		"multi-step crafting system. Automate this early."
	]
	quest.479AD575EDA643AA.quest_desc: ["Battlemage armor has the highest defense but fewest thread slots. The choice for a hybrid fighter-mage or PvP build."]
